DJANGO_SECRET_KEY=replace-with-a-secure-key
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Use mysql when running XAMPP MySQL.
DB_ENGINE=mysql
DB_NAME=scrapay
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

CHANNEL_LAYER_BACKEND=inmemory
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=your-brevo-smtp-login
BREVO_SMTP_PASSWORD=your-brevo-smtp-password
BREVO_SMTP_USE_TLS=1
BREVO_SMTP_USE_SSL=0
# Must be a sender email/domain you have verified inside your Brevo account.
# Consumer mailbox senders are often less reliable than a verified sender/domain in production.
BREVO_SENDER_EMAIL=your-verified-sender@yourdomain.com
OTP_MAX_ATTEMPTS=5

# Production hardening (used when DJANGO_DEBUG=0)
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1

# LOCAL DEV SHORTCUT
# Uncomment this line to print OTPs directly in the Django terminal
# instead of sending real emails. Remove it in production.
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
